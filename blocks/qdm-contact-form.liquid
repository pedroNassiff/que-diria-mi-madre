{% capture submit_button %}
  {% content_for 'block', type: 'contact-form-submit-button', id: 'submit-button' %}
{% endcapture %}

<div
  class="
    qdm-contact-form
    spacing-style size-style
    {% if block.settings.inherit_color_scheme == false %}color-{{ block.settings.color_scheme }}{% endif %}
  "
  style="
    {% render 'spacing-style', settings: block.settings %}
    {% render 'size-style', settings: block.settings %}
  "
  {{ block.shopify_attributes }}
>
  {% assign form_id = block.id | default: section.id | prepend: 'ContactForm-' %}
  {%- form 'contact', id: form_id, class: 'qdm-contact-form__form' -%}
    <input
      name="contact[id]"
      type="hidden"
      value="{{ form_id }}"
    >

    {%- if form.errors and form.id == form_id -%}
      <div
        class="qdm-contact-form__error"
        tabindex="-1"
        autofocus
      >
        {{- 'icon-error.svg' | inline_asset_content -}}

        {{- form.errors.translated_fields.email | capitalize }}
        {{ form.errors.messages.email -}}
      </div>
    {%- endif -%}

    {%- if form.posted_successfully? and form.id == form_id -%}
      <div
        class="qdm-contact-form__success"
        tabindex="-1"
        autofocus
      >
        {{- 'icon-checkmark.svg' | inline_asset_content -}}
        {{- 'blocks.contact_form.post_success' | t -}}
      </div>
    {%- endif -%}

    <div class="qdm-contact-form__row">
      <label
        class="visually-hidden"
        for="ContactForm-name"
      >
        {{- 'blocks.contact_form.name' | t -}}
      </label>
      <input
        type="text"
        id="ContactForm-name"
        class="qdm-contact-form__input"
        autocomplete="name"
        name="contact[name]"
        value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
        placeholder="{{ 'blocks.contact_form.name' | t }}"
      >

      <label
        class="visually-hidden"
        for="ContactForm-email"
      >
        {{- 'blocks.contact_form.email' | t -}}
        <span aria-hidden="true">*</span></label
      >
      <input
        type="email"
        id="ContactForm-email"
        class="qdm-contact-form__input"
        autocomplete="email"
        name="contact[email]"
        spellcheck="false"
        autocapitalize="off"
        value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
        aria-required="true"
        {% if form.errors contains 'email' and form.id == form_id %}
          aria-invalid="true"
          aria-describedby="ContactForm-email-error"
        {% endif %}
        placeholder="{{ 'blocks.contact_form.email' | t }}"
      >
    </div>

    <label
      class="visually-hidden"
      for="ContactForm-subject"
    >
      {{- 'blocks.contact_form.subject' | t -}}
    </label>
    <div class="qdm-contact-form__select-wrapper">
      <select
        id="ContactForm-subject"
        class="qdm-contact-form__input qdm-contact-form__select"
        name="contact[subject]"
        required
      >
        <option
          value=""
          disabled
          selected
        >
          {{- 'blocks.contact_form.subject_placeholder' | t -}}
        </option>
        {%- assign qdm_subject_options = 'product_inquiry,order,shipping,returns,adapted_jewelry,collaborations,other' | split: ',' -%}
        {%- for option in qdm_subject_options -%}
          <option value="{{ 'blocks.contact_form.subject_options.' | append: option | t }}">
            {{- 'blocks.contact_form.subject_options.' | append: option | t -}}
          </option>
        {%- endfor -%}
      </select>
      <svg
        aria-hidden="true"
        focusable="false"
        class="icon icon-caret qdm-contact-form__select-icon"
        width="8"
        height="13"
        viewBox="0 0 8 13"
      >
        {%- render 'icon', icon: 'double-sided-caret' -%}
      </svg>
    </div>

    <label
      class="visually-hidden"
      for="ContactForm-phone"
    >
      {{- 'blocks.contact_form.phone' | t -}}
    </label>
    <input
      type="tel"
      id="ContactForm-phone"
      class="qdm-contact-form__input"
      autocomplete="tel"
      name="contact[phone]"
      pattern="[0-9\-]*"
      value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
      placeholder="{{ 'blocks.contact_form.phone' | t }}"
    >

    <label
      class="visually-hidden"
      for="ContactForm-body"
    >
      {{- 'blocks.contact_form.comment' | t -}}
    </label>
    <textarea
      rows="10"
      id="ContactForm-body"
      class="qdm-contact-form__input qdm-contact-form__input--textarea"
      name="contact[body]"
      placeholder="{{ 'blocks.contact_form.comment' | t }}"
    >
      {{- form.body -}}
    </textarea>

    {{ submit_button }}
  {%- endform -%}
</div>

{% stylesheet %}
  .qdm-contact-form__form {
    display: flex;
    flex-direction: column;
    gap: var(--gap-md);
  }

  .qdm-contact-form__row {
    display: flex;
    flex-direction: column;
    gap: var(--gap-md);

    @media screen and (min-width: 750px) {
      flex-direction: row;
      align-items: center;
    }
  }

  .qdm-contact-form .qdm-contact-form__input {
    width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--qdm-carbon, #262522);
    background-color: transparent;
    padding: var(--padding-lg) var(--padding-xl);
    border-radius: var(--style-border-radius-inputs);
    border: 1.5px solid var(--qdm-amber, #ebb86e);
    -webkit-font-smoothing: antialiased;
    font-family: var(--qdm-font-body, 'Source Sans 3', sans-serif);
  }

  .qdm-contact-form .qdm-contact-form__input:hover {
    background-color: transparent;
  }

  .qdm-contact-form__input::placeholder {
    color: var(--qdm-carbon, #262522);
    opacity: 0.5;
  }

  .qdm-contact-form .qdm-contact-form__input:focus {
    outline: none;
    background-color: transparent;
    border-color: var(--qdm-camel, #c9a787);
  }

  .qdm-contact-form__select-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .qdm-contact-form .qdm-contact-form__select {
    appearance: none;
    -webkit-appearance: none;
    cursor: pointer;
    background-color: transparent;
    padding-inline-end: calc(var(--padding-xl) * 2.5);
  }

  .qdm-contact-form__select:invalid {
    color: var(--qdm-carbon, #262522);
    opacity: 0.5;
  }

  .qdm-contact-form__select-icon {
    position: absolute;
    inset-inline-end: var(--padding-xl);
    pointer-events: none;
    color: var(--qdm-carbon, #262522);
  }

  .qdm-contact-form__input--textarea {
    resize: vertical;
    min-height: var(--input-textarea-min-height);
  }

  .qdm-contact-form__error,
  .qdm-contact-form__success {
    display: flex;
    align-items: center;
    gap: var(--gap-xs);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "QDM · Contacto",
  "tag": null,
  "settings": [
    {
      "type": "select",
      "id": "width",
      "label": "t:settings.width_desktop",
      "options": [
        {
          "value": "fit-content",
          "label": "t:options.fit_content"
        },
        {
          "value": "custom",
          "label": "t:options.custom"
        }
      ],
      "default": "fit-content"
    },
    {
      "type": "range",
      "id": "custom_width",
      "label": "t:settings.width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.width == 'custom' }}"
    },
    {
      "type": "select",
      "id": "width_mobile",
      "label": "t:settings.width_mobile",
      "options": [
        {
          "value": "fit-content",
          "label": "t:options.fit_content"
        },
        {
          "value": "custom",
          "label": "t:options.custom"
        }
      ],
      "default": "fit-content"
    },
    {
      "type": "range",
      "id": "custom_width_mobile",
      "label": "t:settings.width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.width_mobile == 'custom' }}"
    },
    {
      "type": "checkbox",
      "id": "inherit_color_scheme",
      "label": "t:settings.inherit_color_scheme",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1",
      "visible_if": "{{ block.settings.inherit_color_scheme == false }}"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "QDM · Contacto",
      "category": "t:categories.forms"
    }
  ]
}
{% endschema %}
