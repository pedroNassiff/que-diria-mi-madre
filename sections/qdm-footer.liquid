      "label": "Encabezado",
      "default": "Colecciones"
    },
    {
      "type": "link_list",
      "id": "col2_menu",
      "label": "Menú (opcional — sin menú usa los links por defecto)"
    },
    {
      "type": "header",
      "content": "Columna Marca"
    },
    {
      "type": "text",
      "id": "col3_heading",
      "label": "Encabezado",
      "default": "Marca"
    },
    {
      "type": "link_list",
      "id": "col3_menu",
      "label": "Menú (opcional)"
    },
    {
      "type": "header",
      "content": "Columna Ayuda"
    },
    {
      "type": "text",
      "id": "col4_heading",
      "label": "Encabezado",
      "default": "Ayuda"
    },
    {
      "type": "link_list",
      "id": "col4_menu",
      "label": "Menú (opcional)"
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Titular",
      "default": "Una pieza al mes. Nada más."
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "Placeholder email",
      "default": "Tu email"
    },
    {
      "type": "text",
      "id": "newsletter_btn",
      "label": "Texto del botón",
      "default": "Suscribirse"
    }
  ],
  "presets": [
    {
      "name": "QDM · Footer"
    }
  ]
}
{% endschema %}
