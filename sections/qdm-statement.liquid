{%- comment -%}
  QDM · Statement — S4 Homepage
  Sección minimalista: separador + texto centrado + CTA con flecha animada
  data-reveal → scroll reveal al entrar en viewport
{%- endcomment -%}

<section class="qdm-statement">
  <div class="qdm-statement__inner page-width">

    <div class="qdm-statement__divider" aria-hidden="true"></div>

    {%- if section.settings.text != blank -%}
      <p class="qdm-statement__text" data-reveal="fade-up" data-reveal-delay="0">
        {{ section.settings.text }}
      </p>
    {%- endif -%}

    {%- if section.settings.cta_label != blank -%}
      <a
        href="{{ section.settings.cta_url | default: '/pages/manifiesto' }}"
        class="qdm-statement__cta"
        data-reveal="fade-up"
        data-reveal-delay="100"
      >
        <span class="qdm-statement__cta-text">{{ section.settings.cta_label | escape }}</span>
        <span class="qdm-statement__arrow" aria-hidden="true">→</span>
      </a>
    {%- endif -%}

  </div>
</section>

{% stylesheet %}
  .qdm-statement {
    background-color: var(--qdm-cream, #FFFEF7);
    padding-block: 5rem 5.5rem;
  }

  .qdm-statement__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: 100%;
  }

  /* Separador */
  .qdm-statement__divider {
    width: 40px;
    height: 1.5px;
    background-color: var(--qdm-camel, #C9A787);
    margin-bottom: 2.5rem;
  }

  /* Texto */
  .qdm-statement__text {
    font-family: var(--qdm-font-heading, 'Work Sans', sans-serif);
    font-size: clamp(1.25rem, 2.5vw + 0.5rem, 2rem);
    font-weight: 400;
    line-height: 1.45;
    letter-spacing: -0.01em;
    color: var(--qdm-carbon, #262522);
    max-width: 680px;
    margin: 0 0 2.5rem;
  }

  /* CTA */
  .qdm-statement__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--qdm-font-body, 'Source Sans 3', sans-serif);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--qdm-carbon, #262522);
    text-decoration: none;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    position: relative;
    box-shadow: none;
    text-shadow: none;
    /* Reset Heritage color variable */
    --button-color: var(--qdm-carbon, #262522);
  }

  /* Underline animado con pseudo-elemento */
  .qdm-statement__cta::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 1px;
    background-color: transparent;
    transform-origin: left;
    transition: background-color 250ms var(--qdm-ease-hover, ease);
  }

  @media (hover: hover) {
    .qdm-statement__cta:hover::after {
      background-color: var(--qdm-carbon, #262522);
    }
  }

  /* Focus moderno — visible solo con teclado */
  .qdm-statement__cta:focus {
    outline: none;
  }

  .qdm-statement__cta:focus-visible {
    outline: 2px solid var(--qdm-carbon, #262522);
    outline-offset: 6px;
    border-radius: 1px;
  }

  /* Flecha — se mueve a la derecha en hover */
  .qdm-statement__arrow {
    display: inline-block;
    transition: transform 300ms var(--qdm-ease-hover, ease);
  }

  @media (hover: hover) {
    .qdm-statement__cta:hover .qdm-statement__arrow {
      transform: translateX(5px);
    }
  }

  /* Mobile */
  @media (max-width: 767px) {
    .qdm-statement {
      padding-block: 3.5rem 4rem;
    }

    .qdm-statement__text {
      font-size: clamp(1.125rem, 4vw + 0.5rem, 1.5rem);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "QDM · Statement",
  "tag": "section",
  "class": "shopify-section",
  "settings": [
    {
      "type": "textarea",
      "id": "text",
      "label": "Texto del manifiesto",
      "default": "No creemos en la joyería como accesorio. Creemos en la joyería como símbolo. Creamos piezas que no siguen tendencias: cuentan historias."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Texto del CTA",
      "default": "Leer el manifiesto completo"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Link del CTA"
    }
  ],
  "presets": [
    {
      "name": "QDM · Statement"
    }
  ]
}
{% endschema %}
