{%- comment -%}
  QDM · Hero Slider
  Blocks: imagen + label + heading + subheading + CTA
  Animación: GSAP crossfade entre slides + stagger en texto
  Auto-avance: 5 s con barra de progreso
{%- endcomment -%}

<section
  class="qdm-slider"
  data-qdm-slider
  style="--slider-h: {{ section.settings.height_desktop }}vh;"
>
  <div class="qdm-slider__slides">
    {%- for block in section.blocks -%}
      {%- assign is_first = forloop.first -%}
      {%- if is_first -%}
        {%- assign img_loading = 'eager' -%}
        {%- assign img_priority = 'high' -%}
        {%- assign slide_hidden = 'false' -%}
      {%- else -%}
        {%- assign img_loading = 'lazy' -%}
        {%- assign img_priority = 'auto' -%}
        {%- assign slide_hidden = 'true' -%}
      {%- endif -%}

      <article
        class="qdm-slider__slide{% if is_first %} is-active{% endif %}"
        data-slide="{{ forloop.index0 }}"
        aria-hidden="{{ slide_hidden }}"
        {{ block.shopify_attributes }}
      >
        <div class="qdm-slider__media" aria-hidden="true">
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 1920
              | image_tag:
                loading: img_loading,
                fetchpriority: img_priority,
                widths: '768, 1200, 1440, 1920',
                sizes: '100vw',
                class: 'qdm-slider__img'
            }}
          {%- else -%}
            <div class="qdm-slider__placeholder"></div>
          {%- endif -%}
        </div>

        <div class="qdm-slider__overlay" aria-hidden="true"></div>

        <div class="qdm-slider__content">
          {%- if block.settings.label != blank -%}
            <span class="qdm-slider__label" data-slider-el>{{ block.settings.label }}</span>
          {%- endif -%}
          {%- if block.settings.heading != blank -%}
            <h2 class="qdm-slider__heading" data-slider-el>{{ block.settings.heading }}</h2>
          {%- endif -%}
          {%- if block.settings.subheading != blank -%}
            <p class="qdm-slider__sub" data-slider-el>{{ block.settings.subheading }}</p>
          {%- endif -%}
          {%- if block.settings.cta_label != blank -%}
            <a
              href="{{ block.settings.cta_url | default: '#' }}"
              class="qdm-slider__cta"
              data-slider-el
            >
              {{ block.settings.cta_label }}
              <span aria-hidden="true">→</span>
            </a>
          {%- endif -%}
        </div>
      </article>
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    <button class="qdm-slider__arrow qdm-slider__arrow--prev" data-slider-prev aria-label="Slide anterior">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <button class="qdm-slider__arrow qdm-slider__arrow--next" data-slider-next aria-label="Slide siguiente">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <div class="qdm-slider__footer">
      <div class="qdm-slider__dots" role="tablist" aria-label="Navegación de slides">
        {%- for block in section.blocks -%}
          <button
            class="qdm-slider__dot{% if forloop.first %} is-active{% endif %}"
            data-slider-dot="{{ forloop.index0 }}"
            role="tab"
            aria-selected="{{ forloop.first }}"
            aria-label="Ir al slide {{ forloop.index }}"
          ></button>
        {%- endfor -%}
      </div>
      <div class="qdm-slider__progress" aria-hidden="true">
        <div class="qdm-slider__bar" data-slider-bar></div>
      </div>
    </div>
  {%- endif -%}
</section>

{% stylesheet %}
  .qdm-slider {
    position: relative;
    width: 100%;
    height: var(--slider-h, 92vh);
    overflow: hidden;
    background-color: var(--qdm-carbon, #262522);
  }

  /* ── Slides stack ── */
  .qdm-slider__slides {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .qdm-slider__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    user-select: none;
  }

  .qdm-slider__slide.is-active {
    opacity: 1;
    pointer-events: auto;
    user-select: auto;
  }

  /* ── Media ── */
  .qdm-slider__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .qdm-slider__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .qdm-slider__placeholder {
    width: 100%;
    height: 100%;
    background-color: var(--qdm-sand, #E0DED7);
  }

  /* ── Gradient overlay ── */
  .qdm-slider__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to top,
      rgba(38, 37, 34, 0.72) 0%,
      rgba(38, 37, 34, 0.24) 50%,
      rgba(38, 37, 34, 0.0) 100%
    );
  }

  /* ── Content ── */
  .qdm-slider__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 2;
    padding: 3rem 4rem 5rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .qdm-slider__label {
    display: inline-block;
    font-family: var(--qdm-font-body, 'Source Sans 3', sans-serif);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--qdm-amber, #EBB86E);
  }

  .qdm-slider__heading {
    font-family: var(--qdm-font-heading, 'Work Sans', sans-serif);
    font-size: clamp(2.25rem, 5vw, 4rem);
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--qdm-cream, #FFFEF7);
    margin: 0;
    max-width: 16ch;
  }

  .qdm-slider__sub {
    font-family: var(--qdm-font-body, 'Source Sans 3', sans-serif);
    font-size: clamp(0.9375rem, 1.5vw, 1.125rem);
    font-weight: 400;
    line-height: 1.5;
    color: rgba(255, 254, 247, 0.75);
    margin: 0;
    max-width: 44ch;
  }

  .qdm-slider__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
    font-family: var(--qdm-font-body, 'Source Sans 3', sans-serif);
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--qdm-cream, #FFFEF7);
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 254, 247, 0.4);
    padding-bottom: 2px;
    transition: border-color 300ms var(--qdm-ease-hover, ease), color 300ms var(--qdm-ease-hover, ease);
  }

  .qdm-slider__cta:hover {
    color: var(--qdm-amber, #EBB86E);
    border-color: var(--qdm-amber, #EBB86E);
  }

  /* ── Arrows ── */
  .qdm-slider__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(255, 254, 247, 0.3);
    background: rgba(38, 37, 34, 0.3);
    color: var(--qdm-cream, #FFFEF7);
    cursor: pointer;
    backdrop-filter: blur(4px);
    transition: background 250ms ease, border-color 250ms ease;
  }

  .qdm-slider__arrow:hover {
    background: rgba(38, 37, 34, 0.6);
    border-color: rgba(255, 254, 247, 0.6);
  }

  .qdm-slider__arrow--prev { left: 1.5rem; }
  .qdm-slider__arrow--next { right: 1.5rem; }

  /* ── Footer (dots + progress) ── */
  .qdm-slider__footer {
    position: absolute;
    bottom: 1.75rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.625rem;
  }

  .qdm-slider__dots {
    display: flex;
    gap: 0.5rem;
  }

  .qdm-slider__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 254, 247, 0.4);
    cursor: pointer;
    padding: 0;
    transition: background 250ms ease, transform 250ms ease;
  }

  .qdm-slider__dot.is-active {
    background: var(--qdm-cream, #FFFEF7);
    transform: scale(1.4);
  }

  .qdm-slider__progress {
    width: 120px;
    height: 1px;
    background: rgba(255, 254, 247, 0.2);
    overflow: hidden;
    border-radius: 1px;
  }

  .qdm-slider__bar {
    height: 100%;
    background: var(--qdm-amber, #EBB86E);
    transform-origin: left center;
    transform: scaleX(0);
    border-radius: 1px;
  }

  /* ── Mobile ── */
  @media (max-width: 767px) {
    .qdm-slider {
      height: 90svh;
    }

    .qdm-slider__content {
      padding: 2rem 1.5rem 4.5rem;
    }

    .qdm-slider__arrow {
      width: 36px;
      height: 36px;
    }

    .qdm-slider__arrow--prev { left: 0.75rem; }
    .qdm-slider__arrow--next { right: 0.75rem; }
  }

  /* ── Reducir movimiento ── */
  @media (prefers-reduced-motion: reduce) {
    .qdm-slider__slide,
    .qdm-slider__bar,
    .qdm-slider__dot {
      transition: none !important;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    const AUTOPLAY_MS   = 5000;
    const TRANSITION_MS = 0.55; // segundos para GSAP

    function initSlider(section) {
      const root      = section.querySelector('[data-qdm-slider]') || section;
      const slides    = Array.from(root.querySelectorAll('[data-slide]'));
      const dots      = Array.from(root.querySelectorAll('[data-slider-dot]'));
      const prevBtn   = root.querySelector('[data-slider-prev]');
      const nextBtn   = root.querySelector('[data-slider-next]');
      const bar       = root.querySelector('[data-slider-bar]');
      const useGsap   = typeof gsap !== 'undefined';
      const REDUCED   = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (slides.length === 0) return;

      let current      = 0;
      let isAnimating  = false;
      let progressTween = null;
      let autoTimer    = null;

      // Establece estado inicial visible del primer slide
      slides.forEach((slide, i) => {
        if (i !== 0 && useGsap) {
          gsap.set(slide, { opacity: 0, zIndex: 0 });
        }
      });

      function setDots(idx) {
        dots.forEach((d, i) => {
          d.classList.toggle('is-active', i === idx);
          d.setAttribute('aria-selected', i === idx ? 'true' : 'false');
        });
      }

      function startProgress() {
        if (!bar || REDUCED) return;
        if (progressTween) progressTween.kill();
        if (useGsap) {
          progressTween = gsap.fromTo(bar,
            { scaleX: 0 },
            {
              scaleX: 1,
              duration: AUTOPLAY_MS / 1000,
              ease: 'none',
              onComplete: () => goTo(current + 1)
            }
          );
        }
      }

      function stopProgress() {
        if (progressTween) progressTween.kill();
        clearTimeout(autoTimer);
      }

      function goTo(idx) {
        if (isAnimating) return;
        const total = slides.length;
        const next  = ((idx % total) + total) % total;
        if (next === current) return;

        isAnimating = true;
        stopProgress();

        const outSlide = slides[current];
        const inSlide  = slides[next];

        if (useGsap && !REDUCED) {
          const outEls = outSlide.querySelectorAll('[data-slider-el]');
          const inEls  = inSlide.querySelectorAll('[data-slider-el]');

          gsap.set(inSlide, { opacity: 0, zIndex: 1 });
          gsap.set(outSlide, { zIndex: 0 });

          const tl = gsap.timeline({
            onComplete: () => {
              outSlide.classList.remove('is-active');
              outSlide.setAttribute('aria-hidden', 'true');
              inSlide.classList.add('is-active');
              inSlide.setAttribute('aria-hidden', 'false');
              current = next;
              isAnimating = false;
              setDots(current);
              startProgress();
            }
          });

          // Fade out texto saliente
          tl.to(outEls, {
            opacity: 0,
            y: -12,
            duration: 0.25,
            ease: 'power2.in',
            stagger: 0.04
          });

          // Crossfade slide
          tl.to(inSlide, { opacity: 1, duration: TRANSITION_MS, ease: 'power2.inOut' }, '-=0.1');

          // Fade in texto entrante
          tl.fromTo(inEls,
            { opacity: 0, y: 20 },
            { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out', stagger: 0.07 },
            '-=0.25'
          );

        } else {
          // Sin GSAP o reduced motion: cambio directo
          outSlide.classList.remove('is-active');
          outSlide.setAttribute('aria-hidden', 'true');
          inSlide.classList.add('is-active');
          inSlide.setAttribute('aria-hidden', 'false');
          current = next;
          isAnimating = false;
          setDots(current);
          startProgress();
        }
      }

      // Eventos
      if (prevBtn) prevBtn.addEventListener('click', () => goTo(current - 1));
      if (nextBtn) nextBtn.addEventListener('click', () => goTo(current + 1));

      dots.forEach(dot => {
        dot.addEventListener('click', () => goTo(parseInt(dot.dataset.sliderDot, 10)));
      });

      // Swipe en mobile
      let touchStartX = 0;
      root.addEventListener('touchstart', e => { touchStartX = e.changedTouches[0].clientX; }, { passive: true });
      root.addEventListener('touchend', e => {
        const delta = e.changedTouches[0].clientX - touchStartX;
        if (Math.abs(delta) > 50) goTo(current + (delta < 0 ? 1 : -1));
      }, { passive: true });

      // Pausar en hover
      root.addEventListener('mouseenter', stopProgress);
      root.addEventListener('mouseleave', startProgress);

      // Teclado
      root.addEventListener('keydown', e => {
        if (e.key === 'ArrowLeft')  goTo(current - 1);
        if (e.key === 'ArrowRight') goTo(current + 1);
      });

      // Arrancar
      setDots(0);
      startProgress();
    }

    function mountAll() {
      document.querySelectorAll('[data-qdm-slider]').forEach(el => {
        if (!el.dataset.sliderMounted) {
          el.dataset.sliderMounted = '1';
          initSlider(el);
        }
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', mountAll);
    } else {
      mountAll();
    }

    document.addEventListener('shopify:section:load', e => {
      const section = e.target;
      if (section.querySelector('[data-qdm-slider]')) {
        delete section.querySelector('[data-qdm-slider]').dataset.sliderMounted;
        initSlider(section.querySelector('[data-qdm-slider]'));
      }
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "QDM · Hero Slider",
  "tag": "section",
  "class": "shopify-section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "range",
      "id": "height_desktop",
      "min": 60,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Altura (desktop)",
      "default": 90
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen",
          "info": "Recomendado: 1920×1080px o superior, horizontal."
        },
        {
          "type": "text",
          "id": "label",
          "label": "Etiqueta pequeña",
          "default": "Nueva colección"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Título principal",
          "default": "Lo que siempre quisiste decirle"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subtítulo",
          "default": "Joyas que hablan cuando las palabras no alcanzan."
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "Texto del botón",
          "default": "Explorar piezas"
        },
        {
          "type": "url",
          "id": "cta_url",
          "label": "Enlace del botón"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "QDM · Hero Slider",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "label": "Nueva colección",
            "heading": "Lo que siempre quisiste decirle",
            "subheading": "Joyas que hablan cuando las palabras no alcanzan.",
            "cta_label": "Explorar piezas"
          }
        },
        {
          "type": "slide",
          "settings": {
            "label": "Línea adaptada",
            "heading": "Belleza sin barreras",
            "subheading": "Diseñadas para quienes usan audífonos. Sin renunciar a nada.",
            "cta_label": "Ver joyas adaptadas"
          }
        },
        {
          "type": "slide",
          "settings": {
            "label": "Nuestra historia",
            "heading": "Hechas con intención, llevadas con amor",
            "subheading": "Artesanía europea que acompaña historias reales.",
            "cta_label": "Conocer el manifiesto"
          }
        }
      ]
    }
  ]
}
{% endschema %}
