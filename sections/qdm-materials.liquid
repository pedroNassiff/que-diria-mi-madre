{%- comment -%}
  QDM · Materiales + Proceso — S7 Homepage
  Imagen full-bleed lado izquierdo (55%) + contenido lado derecho (45%) desktop
  Stack mobile (imagen primero, 16:9)
  Fondo crema, bullets con ícono circular + título, 2 CTAs tipo texto
{%- endcomment -%}

<section class="qdm-mat">
  <div class="qdm-mat__inner">

    <!-- Imagen -->
    <div class="qdm-mat__media">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1200 | image_tag: class: 'qdm-mat__img', loading: 'lazy', widths: '600, 900, 1200', sizes: '(min-width: 750px) 55vw, 100vw', alt: section.settings.image.alt }}
      {%- else -%}
        <div class="qdm-mat__img-placeholder">
          {{ 'lifestyle-2' | placeholder_svg_tag: 'qdm-mat__svg' }}
        </div>
      {%- endif -%}
    </div>

    <!-- Contenido -->
    <div class="qdm-mat__content" data-reveal="fade-up" data-reveal-delay="80">
      <div class="qdm-mat__content-inner">

        {%- if section.settings.eyebrow != blank -%}
          <p class="qdm-mat__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}

        {%- if section.settings.title != blank -%}
          <h2 class="qdm-mat__title">{{ section.settings.title }}</h2>
        {%- endif -%}

        <span class="qdm-mat__divider" aria-hidden="true"></span>

        {%- assign bullets = section.blocks | where: 'type', 'bullet' -%}
        {%- if bullets.size > 0 -%}
          <ul class="qdm-mat__bullets" role="list">
            {%- for block in bullets -%}
              {%- if block.settings.heading != blank -%}
                <li class="qdm-mat__bullet" {{ block.shopify_attributes }}>

                  <!-- Ícono circular -->
                  <div class="qdm-mat__bullet-icon" aria-hidden="true">
                    {%- if block.settings.icon_image != blank -%}
                      <img
                        src="{{ block.settings.icon_image | image_url: width: 96 }}"
                        alt=""
                        width="48"
                        height="48"
                        loading="lazy"
                      >
                    {%- else -%}
                      <span class="qdm-mat__bullet-icon-dot">·</span>
                    {%- endif -%}
                  </div>

                  <span class="qdm-mat__bullet-heading">{{ block.settings.heading | escape }}</span>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}

        <div class="qdm-mat__ctas">
          {%- if section.settings.cta1_label != blank -%}
            <a
              href="{{ section.settings.cta1_url | default: '/pages/materiales' }}"
              class="qdm-mat__cta"
            >
              <span class="qdm-mat__cta-text">{{ section.settings.cta1_label | escape }}</span>
              <span class="qdm-mat__cta-arrow" aria-hidden="true">→</span>
            </a>
          {%- endif -%}
          {%- if section.settings.cta2_label != blank -%}
            <a
              href="{{ section.settings.cta2_url | default: '/pages/proceso' }}"
              class="qdm-mat__cta"
            >
              <span class="qdm-mat__cta-text">{{ section.settings.cta2_label | escape }}</span>
              <span class="qdm-mat__cta-arrow" aria-hidden="true">→</span>
            </a>
          {%- endif -%}
        </div>

      </div>
    </div>

  </div>
</section>

{% stylesheet %}
  /* ─── Sección ─── */
  .qdm-mat {
    background-color: var(--qdm-cream, #FFFEF7);
    overflow: hidden;
  }

  .qdm-mat__inner {
    display: grid;
    grid-template-columns: 55% 1fr;
  }

  /* ─── Media ─── */
  .qdm-mat__media {
    position: relative;
    display: flex;
    width: 100%;
    height: 60svh;
    min-height: 420px;
    max-height: 700px;
    overflow: hidden;
  }

  .qdm-mat__img {
    object-fit: cover;
    width: 100%;
    height: 100%;
    display: block;
  }

  .qdm-mat__img-placeholder {
    position: absolute;
    inset: 0;
    background-color: var(--qdm-sand, #E0DED7);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .qdm-mat__svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ─── Contenido ─── */
  .qdm-mat__content {
    display: flex;
    align-items: center;
    padding-block: 5rem;
    padding-inline: 4rem 3rem;
    background-color: var(--qdm-cream, #FFFEF7);
  }

  .qdm-mat__content-inner {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    max-width: 420px;
  }

  /* Eyebrow */
  .qdm-mat__eyebrow {
    font-family: var(--qdm-font-body, 'Source Sans 3', sans-serif);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(38, 37, 34, 0.5);
    margin: 0;
  }

  /* Título */
  .qdm-mat__title {
    font-family: var(--qdm-font-heading, 'Work Sans', sans-serif);
    font-size: clamp(1.625rem, 2.5vw, 2.25rem);
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: var(--qdm-carbon, #262522);
    margin: 0;
  }

  /* Separador */
  .qdm-mat__divider {
    display: block;
    width: 32px;
    height: 1.5px;
    background-color: var(--qdm-camel, #C9A787);
    flex-shrink: 0;
  }

  /* ─── Bullets ─── */
  .qdm-mat__bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .qdm-mat__bullet {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  /* Ícono circular */
  .qdm-mat__bullet-icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background-color: var(--qdm-sand, #E0DED7);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .qdm-mat__bullet-icon img {
    width: 48px;
    height: 48px;
    object-fit: cover;
    border-radius: 50%;
  }

  .qdm-mat__bullet-icon-dot {
    font-size: 1.5rem;
    color: var(--qdm-camel, #C9A787);
    line-height: 1;
  }

  .qdm-mat__bullet-heading {
    font-family: var(--qdm-font-body, 'Source Sans 3', sans-serif);
    font-size: 0.9375rem;
    font-weight: 400;
    color: var(--qdm-carbon, #262522);
    line-height: 1.4;
  }

  /* ─── CTAs — estilo igual al botón "Leer el manifiesto" ─── */
  .qdm-mat__ctas {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 0.75rem 1.5rem;
    align-items: center;
    margin-top: 0.25rem;
  }

  .qdm-mat__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--qdm-font-body, 'Source Sans 3', sans-serif);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--qdm-carbon, #262522);
    text-decoration: none;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    position: relative;
    box-shadow: none;
    text-shadow: none;
    --button-color: var(--qdm-carbon, #262522);
  }

  /* Underline animado — aparece solo en hover */
  .qdm-mat__cta::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 1px;
    background-color: transparent;
    transition: background-color 250ms ease;
  }

  @media (hover: hover) {
    .qdm-mat__cta:hover::after {
      background-color: var(--qdm-carbon, #262522);
    }

    .qdm-mat__cta:hover .qdm-mat__cta-arrow {
      transform: translateX(4px);
    }
  }

  .qdm-mat__cta:focus { outline: none; }
  .qdm-mat__cta:focus-visible {
    outline: 2px solid var(--qdm-carbon, #262522);
    outline-offset: 6px;
    border-radius: 1px;
  }

  .qdm-mat__cta-arrow {
    display: inline-block;
    transition: transform 280ms ease;
  }

  /* ─── Mobile ─── */
  @media (max-width: 767px) {
    .qdm-mat__inner {
      grid-template-columns: 1fr;
    }

    .qdm-mat__media {
      height: 56vw;
      min-height: 220px;
      max-height: unset;
    }

    .qdm-mat__content {
      padding: 3rem 1.5rem;
    }

    .qdm-mat__content-inner {
      max-width: 100%;
      gap: 1.5rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .qdm-mat__cta::after,
    .qdm-mat__cta-arrow { transition: none; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "QDM · Materiales",
  "tag": "section",
  "class": "shopify-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto sobre el título (opcional)"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Lo que elegimos y por qué."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen (proceso o detalle de pieza)"
    },
    {
      "type": "url",
      "id": "cta1_url",
      "label": "Link CTA 1"
    },
    {
      "type": "text",
      "id": "cta1_label",
      "label": "Texto CTA 1",
      "default": "Nuestros materiales"
    },
    {
      "type": "url",
      "id": "cta2_url",
      "label": "Link CTA 2"
    },
    {
      "type": "text",
      "id": "cta2_label",
      "label": "Texto CTA 2",
      "default": "Cómo los hacemos"
    }
  ],
  "blocks": [
    {
      "type": "bullet",
      "name": "Punto clave",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Ícono (imagen circular)"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Texto"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "QDM · Materiales",
      "blocks": [
        {
          "type": "bullet",
          "settings": {
            "heading": "Plata de ley 925 certificada por AIDIMME"
          }
        },
        {
          "type": "bullet",
          "settings": {
            "heading": "Plata reciclada en nuestra línea adaptada"
          }
        },
        {
          "type": "bullet",
          "settings": {
            "heading": "Fabricación en Europa con pequeños talleres"
          }
        }
      ]
    }
  ]
}
{% endschema %}
