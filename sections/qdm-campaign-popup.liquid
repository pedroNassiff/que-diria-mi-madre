{%- comment -%}
  QDM · Popup de campaña
  Modal de bienvenida/descuento con captura de email. Vive en el header group
  (sitewide) y se activa/desactiva desde el editor de temas, igual que la
  barra de campaña.

  - Usa <dialog-component> + assets/dialog.js (nativos del tema) para el modal:
    scroll-lock, cierre con click afuera/Escape y animación de apertura/cierre.
  - Usa {% form 'customer' %} para el alta de newsletter — mismo patrón que
    blocks/email-signup.liquid (sin apps de terceros).
  - El trigger (delay + frecuencia de reaparición) lo maneja
    assets/qdm-campaign-popup.js vía localStorage.
{%- endcomment -%}

<script src="{{ 'dialog.js' | asset_url }}" type="module"></script>
<script src="{{ 'qdm-campaign-popup.js' | asset_url }}" type="module"></script>

{%- liquid
  assign redirect_path = section.settings.success_redirect | default: '/'
  assign success_href = redirect_path
  if section.settings.discount_code != blank
    assign success_href = '/discount/' | append: section.settings.discount_code | append: '?redirect=' | append: redirect_path
  endif
-%}

<dialog-component
  class="qdm-campaign-popup"
  data-qdm-campaign-popup
  data-delay="{{ section.settings.delay_seconds | times: 1000 }}"
  data-reappear-days="{{ section.settings.reappear_days }}"
>
  <dialog
    ref="dialog"
    class="qdm-campaign-popup__dialog"
    aria-labelledby="qdm-campaign-popup-heading"
  >
    <button
      ref="closeButton"
      type="button"
      on:click="/closeDialog"
      class="qdm-campaign-popup__close"
      aria-label="Cerrar"
    >
      &times;
    </button>

    <div class="qdm-campaign-popup__grid{% if section.settings.image == blank %} qdm-campaign-popup__grid--no-media{% endif %}">
      {%- if section.settings.image != blank -%}
        <div class="qdm-campaign-popup__media">
          {{
            section.settings.image
            | image_url: width: 800
            | image_tag:
              loading: 'lazy',
              widths: '400, 600, 800',
              sizes: '(min-width: 641px) 420px, 100vw',
              class: 'qdm-campaign-popup__img',
              alt: section.settings.image.alt | default: section.settings.heading
          }}
        </div>
      {%- endif -%}

      <div class="qdm-campaign-popup__content">
        {%- form 'customer', id: 'qdm-campaign-popup-form', class: 'qdm-campaign-popup__form' -%}
          {%- if form.posted_successfully? -%}
            <span data-qdm-just-subscribed hidden></span>
            <h2 id="qdm-campaign-popup-heading" class="qdm-campaign-popup__heading">
              {{ section.settings.success_heading }}
            </h2>
            <p class="qdm-campaign-popup__subheading">{{ section.settings.success_message }}</p>
            <a href="{{ success_href }}" class="qdm-campaign-popup__button">
              {{ section.settings.success_cta_label }}
            </a>
          {%- else -%}
            <h2 id="qdm-campaign-popup-heading" class="qdm-campaign-popup__heading">
              {{ section.settings.heading }}
            </h2>
            {%- if section.settings.subheading != blank -%}
              <p class="qdm-campaign-popup__subheading">{{ section.settings.subheading }}</p>
            {%- endif -%}
            {%- if section.settings.note != blank -%}
              <p class="qdm-campaign-popup__note">{{ section.settings.note }}</p>
            {%- endif -%}

            {%- if form.errors -%}
              <p class="qdm-campaign-popup__error">
                {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
              </p>
            {%- endif -%}

            <label class="visually-hidden" for="qdm-campaign-popup-email">
              {{ section.settings.email_placeholder }}
            </label>
            <input
              id="qdm-campaign-popup-email"
              class="qdm-campaign-popup__input"
              type="email"
              name="contact[email]"
              autocorrect="off"
              autocapitalize="off"
              autocomplete="email"
              placeholder="{{ section.settings.email_placeholder }}"
              required
              {%- if form.errors %}
                autofocus
                aria-invalid="true"
              {%- endif %}
            >
            <button type="submit" class="qdm-campaign-popup__button">
              {{ section.settings.button_label }}
            </button>
          {%- endif -%}
        {%- endform -%}
      </div>
    </div>
  </dialog>
</dialog-component>

{% stylesheet %}
  .qdm-campaign-popup__dialog {
    box-sizing: border-box;
    position: relative;
    padding: 0;
    border: none;
    overflow: hidden;
    max-width: 840px;
    width: calc(100vw - 2rem);
    border-radius: 8px;
    box-shadow: 0 20px 60px rgba(38, 37, 34, 0.25);
  }

  .qdm-campaign-popup__dialog::backdrop {
    background: rgba(38, 37, 34, 0.45);
  }

  .qdm-campaign-popup__dialog[open] {
    animation: qdmCampaignPopupIn var(--qdm-dur-ui, 300ms) var(--qdm-ease-ui, ease) forwards;
  }

  .qdm-campaign-popup__dialog.dialog-closing {
    animation: qdmCampaignPopupOut var(--qdm-dur-ui, 300ms) var(--qdm-ease-ui, ease) forwards;
  }

  @keyframes qdmCampaignPopupIn {
    from {
      opacity: 0;
      transform: translateY(12px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes qdmCampaignPopupOut {
    from {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
    to {
      opacity: 0;
      transform: translateY(12px) scale(0.98);
    }
  }

  .qdm-campaign-popup__close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    line-height: 1;
    color: rgba(38, 37, 34, 0.5);
    background: transparent;
    border: none;
    cursor: pointer;
    z-index: 2;
  }

  @media (hover: hover) {
    .qdm-campaign-popup__close:hover {
      color: var(--qdm-carbon, #262522);
    }
  }

  .qdm-campaign-popup__grid {
    display: grid;
    grid-template-columns: 420px 1fr;
    min-height: 520px;
  }

  .qdm-campaign-popup__grid--no-media {
    grid-template-columns: 1fr;
    min-height: unset;
  }

  .qdm-campaign-popup__media {
    position: relative;
    overflow: hidden;
  }

  .qdm-campaign-popup__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .qdm-campaign-popup__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.75rem;
    padding: 3rem 2.5rem;
    background-color: var(--qdm-cream, #fffef7);
  }

  .qdm-campaign-popup__form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .qdm-campaign-popup__heading {
    font-family: var(--qdm-font-heading, 'Work Sans', sans-serif);
    font-size: 1.375rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    text-align: center;
    color: var(--qdm-carbon, #262522);
    margin: 0;
  }

  .qdm-campaign-popup__subheading {
    font-family: var(--qdm-font-body, 'Source Sans 3', sans-serif);
    font-size: 1rem;
    font-weight: 600;
    text-align: center;
    color: var(--qdm-carbon, #262522);
    margin: 0;
  }

  .qdm-campaign-popup__note {
    font-family: var(--qdm-font-body, 'Source Sans 3', sans-serif);
    font-size: 0.8125rem;
    text-align: center;
    color: rgba(38, 37, 34, 0.55);
    margin: 0 0 0.5rem;
  }

  .qdm-campaign-popup__error {
    font-family: var(--qdm-font-body, 'Source Sans 3', sans-serif);
    font-size: 0.8125rem;
    color: #b3261e;
    margin: 0;
  }

  .qdm-campaign-popup__input {
    box-sizing: border-box;
    width: 100%;
    font-family: var(--qdm-font-body, 'Source Sans 3', sans-serif);
    font-size: 0.9375rem;
    padding: 0.875rem 1rem;
    border: 1px solid var(--qdm-nude, #cfbfb3);
    border-radius: 0;
    background-color: var(--qdm-white, #ffffff);
    color: var(--qdm-carbon, #262522);
  }

  .qdm-campaign-popup__input::placeholder {
    color: rgba(38, 37, 34, 0.4);
  }

  .qdm-campaign-popup__button {
    display: block;
    box-sizing: border-box;
    width: 100%;
    text-align: center;
    font-family: var(--qdm-font-body, 'Source Sans 3', sans-serif);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--qdm-white, #ffffff);
    background-color: var(--qdm-carbon, #262522);
    border: none;
    padding: 0.9375rem 1.25rem;
    text-decoration: none;
    cursor: pointer;
    transition: background-color var(--qdm-dur-hover, 450ms) var(--qdm-ease-hover, ease);
  }

  @media (hover: hover) {
    .qdm-campaign-popup__button:hover {
      background-color: var(--qdm-camel, #c9a787);
    }
  }

  @media screen and (max-width: 640px) {
    .qdm-campaign-popup__grid {
      grid-template-columns: 1fr;
      min-height: unset;
    }

    .qdm-campaign-popup__media {
      display: none;
    }

    .qdm-campaign-popup__content {
      padding: 2.5rem 1.5rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "QDM · Popup de campaña",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen"
    },
    {
      "type": "header",
      "content": "Textos"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "LANZAMIENTO"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subtítulo",
      "default": "30% OFF en tu primer pedido"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Texto pequeño",
      "default": "No te lo pierdas :)"
    },
    {
      "type": "header",
      "content": "Formulario"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Placeholder del email",
      "default": "Email"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto del botón",
      "default": "Obtener 30% off"
    },
    {
      "type": "header",
      "content": "Después de suscribirse"
    },
    {
      "type": "text",
      "id": "discount_code",
      "label": "Código de descuento",
      "info": "Se aplica automáticamente al hacer click en el botón de después de suscribirse."
    },
    {
      "type": "text",
      "id": "success_heading",
      "label": "Título",
      "default": "¡Listo!"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Mensaje",
      "default": "Ya tenés tu 30% de descuento para esta compra."
    },
    {
      "type": "text",
      "id": "success_cta_label",
      "label": "Texto del botón",
      "default": "Ir a comprar"
    },
    {
      "type": "url",
      "id": "success_redirect",
      "label": "Link del botón",
      "info": "A dónde va el visitante después de suscribirse. Por defecto, el home."
    },
    {
      "type": "header",
      "content": "Comportamiento"
    },
    {
      "type": "range",
      "id": "delay_seconds",
      "label": "Segundos antes de aparecer",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "s",
      "default": 5
    },
    {
      "type": "range",
      "id": "reappear_days",
      "label": "Días para volver a mostrarse si se cierra sin suscribirse",
      "min": 1,
      "max": 90,
      "step": 1,
      "unit": "d",
      "default": 7
    }
  ],
  "presets": [
    {
      "name": "QDM · Popup de campaña"
    }
  ]
}
{% endschema %}
