{%- comment -%}
  QDM · Manifiesto — Página editorial
  Texto + citas en fondo arena + imagen + CTA
{%- endcomment -%}

<article class="qdm-manifesto">

  <header class="qdm-manifesto__header">
    <div class="qdm-manifesto__inner">
      <nav class="qdm-manifesto__breadcrumb" aria-label="Breadcrumb">
        <a href="{{ routes.root_url }}" class="qdm-manifesto__bc-link">QDM</a>
        <span class="qdm-manifesto__bc-sep" aria-hidden="true">·</span>
        <span class="qdm-manifesto__bc-current">{{ section.settings.breadcrumb | default: 'Qué Diría Mi Madre' | upcase }}</span>
      </nav>
      <h1 class="qdm-manifesto__title">{{ section.settings.title | default: 'Manifiesto' }}</h1>
      <div class="qdm-manifesto__title-rule" aria-hidden="true"></div>
      {%- if section.settings.subtitle != blank -%}
        <p class="qdm-manifesto__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>
  </header>

  {%- if section.settings.para_1 != blank -%}
    <div class="qdm-manifesto__block">
      <div class="qdm-manifesto__inner">
        <div class="qdm-manifesto__prose">{{ section.settings.para_1 }}</div>
      </div>
    </div>
  {%- endif -%}

  {%- if section.settings.quote_1 != blank -%}
    <div class="qdm-manifesto__quote-band">
      <div class="qdm-manifesto__inner qdm-manifesto__inner--center">
        <span class="qdm-manifesto__quote-deco" aria-hidden="true"></span>
        <p class="qdm-manifesto__quote-text">{{ section.settings.quote_1 }}</p>
      </div>
    </div>
  {%- endif -%}

  {%- if section.settings.para_2 != blank -%}
    <div class="qdm-manifesto__block">
      <div class="qdm-manifesto__inner">
        <div class="qdm-manifesto__prose">{{ section.settings.para_2 }}</div>
      </div>
    </div>
  {%- endif -%}

  {%- if section.settings.image != blank -%}
    <div class="qdm-manifesto__image-band">
      {{
        section.settings.image
        | image_url: width: 900
        | image_tag:
          loading: 'lazy',
          class: 'qdm-manifesto__image',
          widths: '400, 600, 800, 900',
          sizes: '100vw',
          alt: section.settings.image.alt | default: 'QDM · Manifiesto'
      }}
    </div>
  {%- endif -%}

  {%- if section.settings.para_3 != blank -%}
    <div class="qdm-manifesto__block">
      <div class="qdm-manifesto__inner">
        <div class="qdm-manifesto__prose">{{ section.settings.para_3 }}</div>
      </div>
    </div>
  {%- endif -%}

  {%- if section.settings.para_4 != blank -%}
    <div class="qdm-manifesto__block qdm-manifesto__block--spaced">
      <div class="qdm-manifesto__inner">
        <div class="qdm-manifesto__prose">{{ section.settings.para_4 }}</div>
      </div>
    </div>
  {%- endif -%}

  {%- if section.settings.quote_2 != blank -%}
    <div class="qdm-manifesto__quote-band">
      <div class="qdm-manifesto__inner qdm-manifesto__inner--center">
        <span class="qdm-manifesto__quote-deco" aria-hidden="true"></span>
        <p class="qdm-manifesto__quote-text">{{ section.settings.quote_2 }}</p>
      </div>
    </div>
  {%- endif -%}

  {%- if section.settings.para_5 != blank -%}
    <div class="qdm-manifesto__block">
      <div class="qdm-manifesto__inner">
        <div class="qdm-manifesto__prose">{{ section.settings.para_5 }}</div>
      </div>
    </div>
  {%- endif -%}

  {%- if section.settings.cta_label != blank -%}
    <div class="qdm-manifesto__cta-wrap">
      <div class="qdm-manifesto__inner qdm-manifesto__inner--center">
        <a
          href="{{ section.settings.cta_url | default: routes.collections_url }}"
          class="qdm-manifesto__cta"
        >
          {{ section.settings.cta_label | escape }} →
        </a>
      </div>
    </div>
  {%- endif -%}

</article>

{% stylesheet %}
  .qdm-manifesto {
    background-color: var(--qdm-cream, #fffef7);
    padding-block-end: 5rem;
  }

  .qdm-manifesto__inner {
    max-width: 640px;
    margin-inline: auto;
    padding-inline: 1.5rem;
  }

  .qdm-manifesto__inner--center {
    text-align: center;
  }

  /* ── Header ── */
  .qdm-manifesto__header {
    padding-block: 2.5rem 0;
  }

  .qdm-manifesto__breadcrumb {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--qdm-font-body, 'Source Sans 3', sans-serif);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: rgba(38, 37, 34, 0.4);
    margin-bottom: 1.25rem;
  }

  .qdm-manifesto__bc-link {
    color: inherit;
    text-decoration: none;
    transition: color 200ms ease;
  }

  @media (hover: hover) {
    .qdm-manifesto__bc-link:hover {
      color: var(--qdm-carbon, #262522);
    }
  }

  .qdm-manifesto__bc-sep {
    font-size: 0.6875rem;
  }

  .qdm-manifesto__bc-current {
    color: rgba(38, 37, 34, 0.55);
  }

  .qdm-manifesto__title {
    font-family: var(--qdm-font-heading, 'Work Sans', sans-serif);
    font-size: clamp(2.25rem, 9vw, 3.75rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: var(--qdm-carbon, #262522);
    margin: 0 0 1rem;
  }

  .qdm-manifesto__title-rule {
    width: 2rem;
    height: 2px;
    background-color: var(--qdm-amber, #ebb86e);
    margin-bottom: 1.125rem;
  }

  .qdm-manifesto__subtitle {
    font-family: var(--qdm-font-body, 'Source Sans 3', sans-serif);
    font-size: 0.9375rem;
    font-weight: 400;
    color: rgba(38, 37, 34, 0.6);
    line-height: 1.5;
    margin: 0;
  }

  /* ── Body blocks ── */
  .qdm-manifesto__block {
    padding-block-start: 2.5rem;
  }

  .qdm-manifesto__block--spaced {
    padding-block-start: 1.75rem;
  }

  .qdm-manifesto__prose p {
    font-family: var(--qdm-font-body, 'Source Sans 3', sans-serif);
    font-size: 0.9375rem;
    font-weight: 400;
    line-height: 1.7;
    color: var(--qdm-carbon, #262522);
    margin: 0;
  }

  /* ── Quote band ── */
  .qdm-manifesto__quote-band {
    background-color: var(--qdm-sand, #e0ded7);
    margin-block-start: 2.5rem;
    padding-block: 3.25rem 3.5rem;
  }

  .qdm-manifesto__quote-deco {
    display: block;
    width: 2.5rem;
    height: 2px;
    background-color: var(--qdm-amber, #ebb86e);
    margin: 0 auto 2rem;
  }

  .qdm-manifesto__quote-text {
    font-family: var(--qdm-font-heading, 'Work Sans', sans-serif);
    font-size: clamp(1.25rem, 4.5vw, 1.875rem);
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.3;
    color: var(--qdm-carbon, #262522);
    margin: 0;
    max-width: 420px;
    margin-inline: auto;
  }

  /* ── Image ── */
  .qdm-manifesto__image-band {
    margin-block-start: 2.5rem;
    overflow: hidden;
  }

  .qdm-manifesto__image {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  /* ── CTA ── */
  .qdm-manifesto__cta-wrap {
    padding-block-start: 3rem;
  }

  .qdm-manifesto__cta {
    display: inline-flex;
    align-items: center;
    font-family: var(--qdm-font-body, 'Source Sans 3', sans-serif);
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--qdm-carbon, #262522);
    background-color: var(--qdm-amber, #ebb86e);
    border: 1.5px solid var(--qdm-amber, #ebb86e);
    padding: 0.875rem 2rem;
    text-decoration: none;
    transition:
      background-color 200ms ease,
      border-color 200ms ease;
    -webkit-tap-highlight-color: transparent;
  }

  @media (hover: hover) {
    .qdm-manifesto__cta:hover {
      background-color: var(--qdm-camel, #c9a787);
      border-color: var(--qdm-camel, #c9a787);
    }
  }

  @media (max-width: 767px) {
    .qdm-manifesto__header {
      padding-block-start: 2rem;
    }

    .qdm-manifesto__block {
      padding-block-start: 2rem;
    }

    .qdm-manifesto__block--spaced {
      padding-block-start: 1.5rem;
    }

    .qdm-manifesto__quote-band {
      margin-block-start: 2rem;
      padding-block: 2.75rem 3rem;
    }

    .qdm-manifesto__image-band {
      margin-block-start: 2rem;
    }

    .qdm-manifesto__cta-wrap {
      padding-block-start: 2.5rem;
    }

    .qdm-manifesto {
      padding-block-end: 4rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .qdm-manifesto__cta {
      transition: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "QDM · Manifiesto",
  "tag": "section",
  "class": "shopify-section",
  "settings": [
    {
      "type": "header",
      "content": "Encabezado"
    },
    {
      "type": "text",
      "id": "breadcrumb",
      "label": "Breadcrumb — segundo nivel",
      "default": "Qué Diría Mi Madre"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Manifiesto"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "El alma de lo que hacemos."
    },
    {
      "type": "header",
      "content": "Párrafo 1"
    },
    {
      "type": "richtext",
      "id": "para_1",
      "label": "Texto",
      "default": "<p>Nace como una respuesta al «qué dirán».</p><p>Una reivindicación de la libertad de ser uno mismo.</p><p>De hacer lo que uno desea. De mostrarse tal como es.</p><p>Más allá de las expectativas. De lo que se considera correcto, atractivo o aceptable.</p>"
    },
    {
      "type": "header",
      "content": "Cita 1"
    },
    {
      "type": "text",
      "id": "quote_1",
      "label": "Texto de la cita",
      "default": "No creemos en la joyería como accesorio. Creemos en la joyería como símbolo."
    },
    {
      "type": "header",
      "content": "Párrafo 2"
    },
    {
      "type": "richtext",
      "id": "para_2",
      "label": "Texto",
      "default": "<p>Creamos piezas originales que no siguen tendencias: cuentan historias.</p><p>Cada diseño nace con intención, carácter y una identidad propia.</p><p>No trabajamos con grandes volúmenes.</p><p>Elegimos la curaduría antes que la cantidad.</p><p>La calidad antes que la rotación.</p><p>El significado antes que la moda.</p>"
    },
    {
      "type": "header",
      "content": "Imagen editorial"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen"
    },
    {
      "type": "header",
      "content": "Párrafo 3"
    },
    {
      "type": "richtext",
      "id": "para_3",
      "label": "Texto",
      "default": "<p>Nuestras piezas representan vínculos.</p><p>La conexión con la familia.</p><p>La complicidad con los amigos.</p><p>La relación más importante: la que tenemos con nosotras mismas.</p>"
    },
    {
      "type": "header",
      "content": "Párrafo 4"
    },
    {
      "type": "richtext",
      "id": "para_4",
      "label": "Texto",
      "default": "<p>Hablamos de resiliencia. De fuerza silenciosa.</p><p>De momentos que marcan un antes y un después.</p><p>De recuerdos que se transforman en símbolos.</p>"
    },
    {
      "type": "header",
      "content": "Cita 2"
    },
    {
      "type": "text",
      "id": "quote_2",
      "label": "Texto de la cita",
      "default": "No vendemos joyas. Creamos objetos con alma."
    },
    {
      "type": "header",
      "content": "Párrafo 5"
    },
    {
      "type": "richtext",
      "id": "para_5",
      "label": "Texto",
      "default": "<p>Pequeños recordatorios de quién sos, de dónde venís y de todo lo que sos capaz de sostener.</p><p>Porque lo que se lleva puesto también puede llevar significado.</p>"
    },
    {
      "type": "header",
      "content": "CTA"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Texto del botón",
      "default": "Explorar la colección"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "URL del botón"
    }
  ],
  "presets": [
    {
      "name": "QDM · Manifiesto"
    }
  ]
}
{% endschema %}
