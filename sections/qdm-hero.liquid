{%- comment -%}
  QDM · Hero — sección principal homepage
  Animaciones: parallax imagen/video (solo desktop)
  data-hero         → wrapper, target para initHero()
  data-hero-image   → media de fondo, target para parallax
  Preparado para video: agregar video en settings para activarlo.
{%- endcomment -%}

<section
  class="qdm-hero"
  data-hero
  {% if section.settings.image != blank %}
    style="--qdm-hero-min-height: {{ section.settings.min_height_desktop }}vh;"
  {% endif %}
>
  {%- if section.settings.video != blank -%}
    <div class="qdm-hero__media" data-hero-image aria-hidden="true">
      {{
        section.settings.video
        | video_tag:
          autoplay: true,
          loop: true,
          muted: true,
          playsinline: true,
          class: 'qdm-hero__video'
      }}
    </div>
  {%- elsif section.settings.image != blank -%}
    <div class="qdm-hero__media" data-hero-image aria-hidden="true">
      {{
        section.settings.image
        | image_url: width: 1920
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          widths: '768, 1200, 1440, 1920',
          sizes: '100vw',
          class: 'qdm-hero__img'
      }}
    </div>
  {%- else -%}
    <div class="qdm-hero__media qdm-hero__media--placeholder" data-hero-image aria-hidden="true"></div>
  {%- endif -%}
</section>

{% stylesheet %}
  .qdm-hero {
    position: relative;
    display: flex;
    align-items: flex-end;
    min-height: var(--qdm-hero-min-height, 92vh);
    overflow: hidden;
    background-color: var(--qdm-carbon, #262522);
  }

  /* Media / imagen de fondo */
  .qdm-hero__media {
    position: absolute;
    inset: -15% 0 -15%;  /* margen extra para el parallax */
    z-index: 0;
  }

  .qdm-hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .qdm-hero__media--placeholder {
    background-color: var(--qdm-sand, #E0DED7);
  }

  /* Video */
  .qdm-hero__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* Mobile */
  @media (max-width: 767px) {
    .qdm-hero {
      min-height: 100svh;
    }
  }

  /* Reducción de movimiento — el JS ya lo maneja, pero por si acaso */
  @media (prefers-reduced-motion: reduce) {
    .qdm-hero__media {
      inset: 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "QDM · Hero",
  "tag": "section",
  "class": "shopify-section",
  "settings": [
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video de fondo",
      "info": "Cuando se sube un video, reemplaza la imagen. MP4 recomendado."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen de fondo",
      "info": "Se usa cuando no hay video. Recomendado: 1920×1080px o superior, horizontal."
    },
    {
      "type": "range",
      "id": "min_height_desktop",
      "min": 60,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Altura mínima (desktop)",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "QDM · Hero"
    }
  ]
}
{% endschema %}
