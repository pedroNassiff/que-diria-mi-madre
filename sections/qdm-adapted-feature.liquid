{%- comment -%}
  QDM · Joyería Adaptada — sección homepage (S6)
  Diferenciador clave de la marca: joyería para personas con audífonos.
  Layout: 2 columnas (texto izquierda, imagen derecha) desktop / stack mobile
  data-reveal → animaciones scroll reveal
{%- endcomment -%}

<section class="qdm-adapted" data-section-id="{{ section.id }}">
  <div class="qdm-adapted__inner">

    {%- comment -%} Columna imagen — izquierda en desktop, arriba en mobile {%- endcomment -%}
    <div class="qdm-adapted__media">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 960
          | image_tag:
            loading: 'lazy',
            widths: '480, 640, 800, 960',
            sizes: '(min-width: 768px) 50vw, 100vw',
            class: 'qdm-adapted__img',
            alt: section.settings.image.alt | escape
        }}
      {%- else -%}
        <div class="qdm-adapted__img-placeholder"></div>
      {%- endif -%}
    </div>

    {%- comment -%} Columna texto — derecha en desktop, abajo en mobile {%- endcomment -%}
    <div class="qdm-adapted__text" data-reveal="fade-up" data-reveal-delay="0">

      <div class="qdm-adapted__content-zone">
        {%- if section.settings.caracol_image != blank -%}
          <div class="qdm-adapted__caracol" aria-hidden="true">
            {{
              section.settings.caracol_image
              | image_url: width: 1200
              | image_tag: loading: 'lazy', widths: '600, 900, 1200'
            }}
          </div>
        {%- endif -%}

        {%- if section.settings.badge != blank -%}
          <p class="qdm-adapted__badge">{{ section.settings.badge | escape }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="qdm-adapted__title">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.body != blank -%}
          <div class="qdm-adapted__body rte">{{ section.settings.body }}</div>
        {%- endif -%}

        {%- if section.settings.bullets_enabled -%}
          <ul class="qdm-adapted__bullets">
            {%- if section.settings.bullet_1 != blank -%}
              <li>{{ section.settings.bullet_1 | escape }}</li>
            {%- endif -%}
            {%- if section.settings.bullet_2 != blank -%}
              <li>{{ section.settings.bullet_2 | escape }}</li>
            {%- endif -%}
            {%- if section.settings.bullet_3 != blank -%}
              <li>{{ section.settings.bullet_3 | escape }}</li>
            {%- endif -%}
          </ul>
        {%- endif -%}
      </div>

      {%- if section.settings.email_button_label != blank -%}
        {%- form 'customer', class: 'qdm-adapted__form' -%}
          {%- if form.posted_successfully? -%}
            <p class="qdm-adapted__form-success">¡Gracias! Te avisamos apenas lancemos.</p>
          {%- else -%}
            {%- if section.settings.email_label != blank -%}
              <label for="AdaptedNewsletter-{{ section.id }}" class="qdm-adapted__form-label">
                {{ section.settings.email_label | escape }}
              </label>
            {%- endif -%}
            <input type="hidden" name="contact[tags]" value="newsletter,joyas-adaptadas">
            <div class="qdm-adapted__form-row">
              <input
                type="email"
                name="contact[email]"
                id="AdaptedNewsletter-{{ section.id }}"
                class="qdm-adapted__form-input"
                placeholder="Tu email"
                autocomplete="email"
                required
              >
              <button type="submit" class="qdm-adapted__form-submit">
                {{ section.settings.email_button_label | escape }}
              </button>
            </div>
            {%- if form.errors -%}
              <p class="qdm-adapted__form-error">
                {{ form.errors.messages['email'] | default: 'Ingresá un email válido.' }}
              </p>
            {%- endif -%}
          {%- endif -%}
        {%- endform -%}
      {%- endif -%}

      {%- if section.settings.trust_badge != blank -%}
        <p class="qdm-adapted__trust">{{ section.settings.trust_badge | escape }}</p>
      {%- endif -%}

    </div>

  </div>
</section>

{% stylesheet %}
  .qdm-adapted {
    background-color: var(--qdm-cream, #FFFEF7);
    overflow: hidden;
  }

  /* Desktop: imagen izquierda llena todo el alto, texto derecha con padding */
  .qdm-adapted__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: stretch;
  }

  /* ── Imagen ── */
  .qdm-adapted__media {
    position: relative;
    overflow: hidden;
    min-height: 520px;
  }

  .qdm-adapted__img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center top;
  }

  .qdm-adapted__img-placeholder {
    width: 100%;
    height: 100%;
    min-height: 520px;
    background-color: var(--qdm-nude, #CFBFB3);
  }

  /* ── Texto ── */
  .qdm-adapted__text {
    position: relative;
    overflow: hidden;
    padding: 4rem 4rem 4rem 4rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  /* Zona de contenido (badge/título/body/bullets) — contexto de
     posición para el caracol, así su base queda siempre pegada
     al final de este bloque (justo antes del form), sin importar
     cuánto texto haya. */
  .qdm-adapted__content-zone {
    position: relative;
  }

  /* Caracol — marca de agua de fondo. En desktop sangra por el
     borde derecho (~10% de la imagen queda fuera de pantalla). */
  .qdm-adapted__caracol {
    position: absolute;
    right: -20%;
    bottom: -10%;
    width: 55%;
    z-index: -1;
    pointer-events: none;
  }

  .qdm-adapted__caracol img {
    width: 100%;
    height: auto;
    display: block;
    opacity: 0.14;
  }

  /* Badge */
  .qdm-adapted__badge {
    display: inline-block;
    font-family: var(--qdm-font-body, 'Source Sans 3', sans-serif);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--qdm-carbon, #262522);
    background-color: var(--qdm-amber, #EBB86E);
    padding: 0.3rem 0.75rem;
    margin-bottom: 1.5rem;
    align-self: flex-start;
  }

  /* Título */
  .qdm-adapted__title {
    font-family: var(--qdm-font-heading, 'Work Sans', sans-serif);
    font-size: clamp(1.75rem, 3vw + 0.5rem, 3rem);
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--qdm-carbon, #262522);
    margin: 0 0 1.5rem;
  }

  /* Cuerpo */
  .qdm-adapted__body {
    font-family: var(--qdm-font-body, 'Source Sans 3', sans-serif);
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(38, 37, 34, 0.8);
    margin-bottom: 1.75rem;
  }

  .qdm-adapted__body p { margin: 0 0 0.875rem; }
  .qdm-adapted__body p:last-child { margin-bottom: 0; }

  /* Bullets con ✦ */
  .qdm-adapted__bullets {
    list-style: none;
    padding: 0;
    margin: 0 0 2.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .qdm-adapted__bullets li {
    font-family: var(--qdm-font-body, 'Source Sans 3', sans-serif);
    font-size: 0.9375rem;
    color: var(--qdm-carbon, #262522);
    padding-left: 1.5rem;
    position: relative;
  }

  .qdm-adapted__bullets li::before {
    content: '✦';
    position: absolute;
    left: 0;
    font-size: 0.6rem;
    top: 0.35em;
    color: var(--qdm-amber, #EBB86E);
  }

  /* Form de email — reemplaza al CTA */
  .qdm-adapted__form {
    margin-bottom: 1.25rem;
  }

  .qdm-adapted__form-label {
    display: block;
    font-family: var(--qdm-font-body, 'Source Sans 3', sans-serif);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--qdm-carbon, #262522);
    margin-bottom: 0.625rem;
  }

  .qdm-adapted__form-row {
    display: flex;
    gap: 0.625rem;
  }

  .qdm-adapted__form-input {
    flex: 1;
    min-width: 0;
    padding: 0.875rem 1rem;
    background-color: var(--qdm-cream, #FFFEF7);
    border: 1px solid var(--qdm-carbon, #262522);
    color: var(--qdm-carbon, #262522);
    font-family: var(--qdm-font-body, 'Source Sans 3', sans-serif);
    font-size: 0.9375rem;
  }

  .qdm-adapted__form-input::placeholder {
    color: rgba(38, 37, 34, 0.45);
  }

  .qdm-adapted__form-input:focus {
    outline: none;
    border-color: var(--qdm-camel, #C9A787);
  }

  .qdm-adapted__form-submit {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 1.5rem;
    background-color: var(--qdm-amber, #EBB86E);
    color: var(--qdm-carbon, #262522);
    font-family: var(--qdm-font-body, 'Source Sans 3', sans-serif);
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    transition: background-color 250ms ease;
  }

  .qdm-adapted__form-submit:hover {
    background-color: var(--qdm-camel, #C9A787);
  }

  .qdm-adapted__form-success {
    font-family: var(--qdm-font-body, 'Source Sans 3', sans-serif);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--qdm-carbon, #262522);
    margin: 0;
  }

  .qdm-adapted__form-error {
    font-family: var(--qdm-font-body, 'Source Sans 3', sans-serif);
    font-size: 0.8125rem;
    color: #b3261e;
    margin: 0.625rem 0 0;
  }

  /* Trust */
  .qdm-adapted__trust {
    font-family: var(--qdm-font-body, 'Source Sans 3', sans-serif);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    color: rgba(38, 37, 34, 0.45);
    margin: 0;
  }

  /* ── Mobile ── */
  @media (max-width: 767px) {
    .qdm-adapted__inner {
      grid-template-columns: 1fr;
    }

    .qdm-adapted__media {
      min-height: unset;
      aspect-ratio: 4 / 5;
    }

    .qdm-adapted__img {
      height: 100%;
    }

    .qdm-adapted__text {
      padding: 2.5rem 1.5rem 3rem;
    }

    /* Caracol mobile: ~25% más grande. bottom: 0 lo pega justo al
       final de la zona badge/título/body/bullets — es decir, su
       base siempre queda arriba del form/botón, sin importar
       cuánto texto haya arriba. */
    .qdm-adapted__caracol {
      top: auto;
      bottom: -20%;
      right: -20%;
      width: 69%;
    }

    /* Form mobile: input y botón apilados, ancho completo */
    .qdm-adapted__form-row {
      flex-direction: column;
    }

    .qdm-adapted__form-submit {
      justify-content: center;
      padding: 1rem 1.5rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "QDM · Joyas Adaptadas",
  "tag": "section",
  "class": "shopify-section",
  "settings": [
    {
      "type": "header",
      "content": "Badge"
    },
    {
      "type": "text",
      "id": "badge",
      "label": "Texto del badge",
      "default": "★ Exclusivo QDM"
    },
    {
      "type": "header",
      "content": "Contenido"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titular",
      "default": "Diseñada desde adentro."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Texto principal",
      "default": "<p>Sabemos lo que es. No como tendencia, sino como experiencia vivida.</p><p>Creamos joyería adaptada para personas que usan audífonos porque creemos que ningún dispositivo debería hacer que te sintieras menos tú misma.</p>"
    },
    {
      "type": "header",
      "content": "Bullets"
    },
    {
      "type": "checkbox",
      "id": "bullets_enabled",
      "label": "Mostrar bullets",
      "default": true
    },
    {
      "type": "text",
      "id": "bullet_1",
      "label": "Bullet 1",
      "default": "Compatible con audífonos BTE y RIC"
    },
    {
      "type": "text",
      "id": "bullet_2",
      "label": "Bullet 2",
      "default": "Plata reciclada de ley 925"
    },
    {
      "type": "text",
      "id": "bullet_3",
      "label": "Bullet 3",
      "default": "Fabricada en España"
    },
    {
      "type": "header",
      "content": "Formulario de email"
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "Texto sobre el input",
      "default": "Recibir novedades del lanzamiento"
    },
    {
      "type": "text",
      "id": "email_button_label",
      "label": "Texto del botón",
      "default": "Quiero recibir el aviso"
    },
    {
      "type": "text",
      "id": "trust_badge",
      "label": "Texto de confianza (bajo el formulario)",
      "default": "Fabricada en España · Plata reciclada 925"
    },
    {
      "type": "header",
      "content": "Imagen"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen",
      "info": "Persona real con audífono usando la pieza. Ratio 4:5 recomendado."
    },
    {
      "type": "header",
      "content": "Marca de agua"
    },
    {
      "type": "image_picker",
      "id": "caracol_image",
      "label": "Caracol de identidad",
      "info": "Se muestra de fondo, sangrando por el borde derecho de la columna de texto (ej. QDM-CMYK_04-positivo)."
    }
  ],
  "presets": [
    {
      "name": "QDM · Joyas Adaptadas"
    }
  ]
}
{% endschema %}
