{%- comment -%}
  QDM · Journal — lista de artículos
  Todos los artículos se muestran igual, en grilla.
{%- endcomment -%}

<section class="qdm-journal" data-qdm-journal>
{%- paginate blog.articles by section.settings.articles_per_page -%}

  <!-- ── Header ── -->
  <header class="qdm-journal__header">
    <div class="qdm-journal__header-inner page-width">
      <div class="qdm-journal__header-top">
        <span class="qdm-journal__count">
          {{ blog.articles_count }}
          {%- if blog.articles_count == 1 %} entrada{%- else %} entradas{%- endif %}
        </span>
      </div>
      <h1 class="qdm-journal__title">{{ section.settings.title | default: blog.title }}</h1>
      {%- if section.settings.tagline != blank -%}
        <p class="qdm-journal__tagline">{{ section.settings.tagline }}</p>
      {%- endif -%}
    </div>
  </header>

  <div class="qdm-journal__body page-width">

    {%- if blog.articles_count == 0 -%}
      <p class="qdm-journal__empty">Pronto habrá entradas aquí.</p>
    {%- endif -%}

    <!-- ── Grid: todos los artículos ── -->
    {%- if blog.articles.size > 0 -%}
      <div class="qdm-journal__grid">
        {%- for article in blog.articles -%}
          {% content_for 'block', id: 'qdm-journal-post-card', type: 'qdm-journal-post-card', article: article %}
        {%- endfor -%}
      </div>
    {%- endif -%}

    <!-- ── Pagination ── -->
    {%- if paginate.pages > 1 -%}
      <nav class="qdm-journal__pagination" aria-label="Paginación del journal">
        {%- if paginate.previous -%}
          <a href="{{ paginate.previous.url }}" class="qdm-journal__page-link">← Anterior</a>
        {%- endif -%}
        <span class="qdm-journal__page-info">{{ paginate.current_page }} / {{ paginate.pages }}</span>
        {%- if paginate.next -%}
          <a href="{{ paginate.next.url }}" class="qdm-journal__page-link">Siguiente →</a>
        {%- endif -%}
      </nav>
    {%- endif -%}

  </div>
{%- endpaginate -%}
</section>

{% stylesheet %}
  /* ── Layout base ── */
  .qdm-journal {
    background-color: var(--qdm-cream, #FFFEF7);
    min-height: 60vh;
  }

  /* ── Header ── */
  .qdm-journal__header {
    border-bottom: 1px solid var(--qdm-nude, #CFBFB3);
    padding: 2.75rem 0 2rem;
  }

  .qdm-journal__header-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .qdm-journal__label {
    font-family: var(--qdm-font-body, 'Source Sans 3', sans-serif);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--qdm-camel, #C9A787);
  }

  .qdm-journal__count {
    font-family: var(--qdm-font-body, 'Source Sans 3', sans-serif);
    font-size: 0.8125rem;
    color: var(--qdm-nude, #CFBFB3);
    letter-spacing: 0.04em;
  }

  .qdm-journal__title {
    font-family: var(--qdm-font-heading, 'Work Sans', sans-serif);
    font-size: clamp(2rem, 4.2vw, 3.5rem);
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1.0;
    color: var(--qdm-carbon, #262522);
    margin: 0 0 0.75rem;
  }

  @media (min-width: 768px) {
    .qdm-journal__header {
      padding: 2.35rem 0 1.7rem;
    }

    .qdm-journal__header-top {
      margin-bottom: 0.85rem;
    }

    .qdm-journal__title {
      font-size: clamp(2rem, 3.6vw, 3rem);
      margin-bottom: 0.65rem;
    }
  }

  .qdm-journal__tagline {
    font-family: var(--qdm-font-body, 'Source Sans 3', sans-serif);
    font-size: 1rem;
    line-height: 1.6;
    color: rgba(38, 37, 34, 0.55);
    margin: 0;
    max-width: 52ch;
  }

  /* ── Body ── */
  .qdm-journal__body {
    padding-block: 4rem;
  }

  .qdm-journal__empty {
    font-family: var(--qdm-font-body, 'Source Sans 3', sans-serif);
    color: rgba(38, 37, 34, 0.45);
    text-align: center;
    padding: 4rem 0;
  }

  /* ── Meta (tag · fecha · tiempo) ── */
  .qdm-journal__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.875rem;
  }

  .qdm-journal__tag {
    font-family: var(--qdm-font-body, 'Source Sans 3', sans-serif);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--qdm-amber, #EBB86E);
  }

  .qdm-journal__sep {
    color: var(--qdm-nude, #CFBFB3);
    font-size: 0.75rem;
  }

  .qdm-journal__date,
  .qdm-journal__read-time {
    font-family: var(--qdm-font-body, 'Source Sans 3', sans-serif);
    font-size: 0.8125rem;
    color: rgba(38, 37, 34, 0.5);
  }

  /* ── Grid ── */
  .qdm-journal__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    column-gap: 2rem;
    row-gap: 3rem;
  }

  @media (max-width: 1023px) {
    .qdm-journal__grid {
      grid-template-columns: 1fr 1fr;
      column-gap: 1.5rem;
      row-gap: 2.5rem;
    }
  }

  .qdm-journal__img-placeholder {
    width: 100%;
    height: 100%;
    background-color: var(--qdm-sand, #E0DED7);
  }

  /* ── Pagination ── */
  .qdm-journal__pagination {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 3rem;
    margin-top: 3rem;
    border-top: 1px solid var(--qdm-nude, #CFBFB3);
  }

  .qdm-journal__page-link {
    font-family: var(--qdm-font-body, 'Source Sans 3', sans-serif);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--qdm-carbon, #262522);
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: color 200ms ease;
  }

  .qdm-journal__page-link:hover {
    color: var(--qdm-amber, #EBB86E);
  }

  .qdm-journal__page-info {
    font-family: var(--qdm-font-body, 'Source Sans 3', sans-serif);
    font-size: 0.8125rem;
    color: rgba(38, 37, 34, 0.45);
  }

  /* ── Mobile ── */
  @media (max-width: 767px) {
    .qdm-journal__header {
      padding: 1.75rem 0 1.25rem;
    }

    .qdm-journal__body {
      padding-block: 2.5rem;
    }

    .qdm-journal__grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "QDM · Journal",
  "tag": "section",
  "class": "shopify-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Journal",
      "info": "Si se deja vacío usa el nombre del blog."
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Ideas sobre joyería, diseño e historias reales."
    },
    {
      "type": "range",
      "id": "articles_per_page",
      "min": 3,
      "max": 12,
      "step": 1,
      "label": "Artículos por página",
      "default": 9
    }
  ],
  "presets": [
    {
      "name": "QDM · Journal"
    }
  ]
}
{% endschema %}
