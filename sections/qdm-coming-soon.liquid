{%- comment -%}
  QDM · Coming Soon — Header
  Foto o video grande de encabezado para páginas de líneas que todavía
  no se venden (ej. "Joyas para audífonos"). Sin texto ni CTA propios
  — eso vive en sections/qdm-content-split.liquid, como sección aparte
  debajo de esta, para que cada bloque de la página sea independiente.
{%- endcomment -%}

<section class="qdm-coming-soon" data-section-id="{{ section.id }}">

  <div class="qdm-coming-soon__media page-width{% if section.settings.header_video != blank %} qdm-coming-soon__media--video{% endif %}">
    {%- if section.settings.header_video != blank -%}
      {{
        section.settings.header_video
        | video_tag:
          poster: nil,
          autoplay: true,
          loop: true,
          controls: false,
          muted: true,
          class: 'qdm-coming-soon__video'
      }}
    {%- elsif section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 1600
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          widths: '768, 1200, 1600',
          sizes: '(max-width: 749px) 100vw, 1400px',
          class: 'qdm-coming-soon__img',
          alt: section.settings.image.alt | escape
      }}
    {%- else -%}
      <div class="qdm-coming-soon__img-placeholder"></div>
    {%- endif -%}
  </div>

</section>

{% stylesheet %}
  .qdm-coming-soon {
    background-color: var(--qdm-cream, #FFFEF7);
    padding-block-end: 4rem;
  }

  /* ── Header: foto grande ── */
  .qdm-coming-soon__media {
    padding-block-start: 5rem;
    margin-bottom: 2.5rem;
  }

  /* Doble clase (.page-width.qdm-coming-soon__media) para ganarle en
     especificidad a ".page-width { width: 100% }" sin importar el
     orden de carga entre archivos — 70% ya era 30% más chica que el
     ancho completo; un 35% más chica sobre eso = 45% del total. */
  .qdm-coming-soon__media.page-width {
    width: 45%;
    margin-inline: auto;
  }

  .qdm-coming-soon__img,
  .qdm-coming-soon__img-placeholder {
    width: 100%;
    aspect-ratio: 16 / 9;
    display: block;
    object-fit: cover;
    object-position: center;
  }

  .qdm-coming-soon__img-placeholder {
    background-color: var(--qdm-nude, #CFBFB3);
  }

  /* Video de header — vertical, así que ocupa mucho más ancho/alto
     que la foto 16:9 (que es horizontal). "Casi full" pero sin llegar
     a sangrar los bordes de la página. */
  .qdm-coming-soon__media--video.page-width {
    width: 78%;
    max-width: 780px;
  }

  .qdm-coming-soon__video {
    width: 100%;
    max-height: 85vh;
    aspect-ratio: 3 / 4;
    display: block;
    object-fit: cover;
    object-position: center;
  }

  @media (max-width: 749px) {
    .qdm-coming-soon__media--video.page-width {
      width: 92%;
      max-width: none;
    }

    .qdm-coming-soon__video {
      max-height: 75vh;
      aspect-ratio: 3 / 4;
    }
  }

  /* ── Mobile ── */
  @media (max-width: 749px) {
    .qdm-coming-soon__img,
    .qdm-coming-soon__img-placeholder {
      aspect-ratio: 4 / 5;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "QDM · Coming Soon",
  "tag": "section",
  "class": "shopify-section",
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "video",
      "id": "header_video",
      "label": "Video header (opcional)",
      "info": "Si cargás un video, reemplaza a la foto. Pensado para video vertical — el contenedor es más grande y angosto que el de la foto."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Foto header",
      "info": "Se usa solo si no hay video cargado. Recomendado 16:9 en desktop (se recorta a 4:5 en mobile)."
    }
  ],
  "presets": [
    {
      "name": "QDM · Coming Soon"
    }
  ]
}
{% endschema %}
