{%- comment -%}
  QDM · GA4 view_item_list (dataLayer)
  Requiere `collection` en scope. Render dentro del bloque {% paginate %}
  de la página de colección, para reflejar solo los productos de la página actual.
{%- endcomment -%}
<script>
  (function () {
    window.dataLayer = window.dataLayer || [];
    dataLayer.push({ ecommerce: null });
    dataLayer.push({
      event: 'view_item_list',
      ecommerce: {
        item_list_name: {{ collection.title | json }},
        items: [
          {%- for product in collection.products -%}
            {
              item_id: {{ product.selected_or_first_available_variant.sku | default: product.id | json }},
              item_name: {{ product.title | json }},
              item_brand: {{ product.vendor | json }},
              item_category: {{ product.type | json }},
              price: {{ product.selected_or_first_available_variant.price | times: 0.01 }},
              index: {{ forloop.index0 }}
            }{% unless forloop.last %},{% endunless %}
          {%- endfor -%}
        ]
      }
    });
  })();
</script>
